# Bundestag PDF Browser Configuration
# Copy this file to .env and fill in your values

# ============================================
# REQUIRED: API Configuration
# ============================================

# Your DIP API Key (get from: https://search.dip.bundestag.de/)
DIP_API_KEY=your-api-key-here

# ============================================
# OPTIONAL: API Settings
# ============================================

# API Base URL (default: official DIP API)
# DIP_API_URL=https://search.dip.bundestag.de/api/v1

# ============================================
# OPTIONAL: Cache Settings
# ============================================

# Enable caching to improve performance (true/false)
# Default: true
DIP_CACHE_ENABLED=true

# Cache time-to-live in seconds
# Default: 3600 (1 hour)
# Recommended values: 1800 (30 min), 3600 (1 hour), 7200 (2 hours)
DIP_CACHE_TTL=3600

# ============================================
# OPTIONAL: Logging Settings
# ============================================

# Enable debug mode (true/false)
# Default: false
DIP_DEBUG=false

# Log level (DEBUG, INFO, WARNING, ERROR)
# Default: INFO
LOG_LEVEL=INFO

# ============================================
# OPTIONAL: Performance Tuning
# ============================================

# Default results per page
# Range: 10-100
# Default: 20
# DIP_DEFAULT_PAGE_SIZE=20

# Request timeout in seconds
# Default: 30
# DIP_REQUEST_TIMEOUT=30

# Max retries for failed requests
# Default: 3
# DIP_MAX_RETRIES=3

# ============================================
# OPTIONAL: OpenAI Web Search
# ============================================

# Enable web search for news coverage in AI summaries (true/false)
# Adds a "📰 Media Coverage" section with links to news articles
# Default: true
ENABLE_WEB_SEARCH=true
